<Template>
  <WidgetGroup>
    <SizePolicy>me,e</SizePolicy>
    <Layout>vertical</Layout>
    <Children>
      <WidgetGroup>
        <ObjectName>LibraryWrapper</ObjectName>
        <Layout>vertical</Layout>
        <Size>0me,0me</Size>
        <Children>
          <WidgetGroup>
            <ObjectName>SidebarContainer</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,40max</Size>
            <Children>
              <WidgetGroup>
                <ObjectName>LibraryPreviewSeekContainer</ObjectName>
                <Layout>vertical</Layout>
                <Size>240p,40max</Size>
                <SizePolicy>min,min</SizePolicy>
                <MinimumSize>240,40</MinimumSize>
                <MaximumSize>240,40</MaximumSize>
                <Children>
                  <Overview>
                    <ObjectName>LibraryPreviewSeek</ObjectName>
                    <TooltipId>waveform_overview</TooltipId>
                    <Group>[PreviewDeck1]</Group>
                    <Size>0me,0me</Size>
                    <BgColor>#32323c</BgColor>
                    <SignalHighColor>#D0D0D0</SignalHighColor>
                    <SignalMidColor>#B0B0B0</SignalMidColor>
                    <SignalLowColor>#8A8A8A</SignalLowColor>
                    <SignalRGBHighColor></SignalRGBHighColor>
                    <SignalRGBMidColor></SignalRGBMidColor>
                    <SignalRGBLowColor></SignalRGBLowColor>
                    <SignalColor>#8A8A8A</SignalColor>
                    <PlayedOverlayColor>#40FFFFFF</PlayedOverlayColor>
                    <PlayPosColor>#FFFFFF</PlayPosColor>
                    <EndOfTrackColor>#EA0000</EndOfTrackColor>
                    <ShowCueTimes>false</ShowCueTimes>
                    <Connection>
                      <ConfigKey>[PreviewDeck1],playposition</ConfigKey>
                      <EmitOnDownPress>false</EmitOnDownPress>
                    </Connection>
                  </Overview>
                </Children>
              </WidgetGroup>
              <WidgetGroup>
                <ObjectName>LibraryPreviewDivider</ObjectName>
                <Size>2p,40max</Size>
                <SizePolicy>min,min</SizePolicy>
              </WidgetGroup>
              <SearchBox>
                <ObjectName>SearchBox</ObjectName>
                <Size>0me,40max</Size>
              </SearchBox>
              <PushButton>
                <ObjectName>SidebarButton</ObjectName>
                <Size>80p,40p</Size>
                <NumberStates>2</NumberStates>
                <State>
                  <Number>0</Number>
                  <Text>Show &#8612;</Text>
                </State>
                <State>
                  <Number>1</Number>
                  <Text>Hide &#8614;</Text>
                </State>
                <Connection>
                  <ConfigKey>[Sidebar],sidebar_visible</ConfigKey>
                </Connection>
              </PushButton>
            </Children>
          </WidgetGroup>
          <WidgetGroup>
            <SizePolicy>me,me</SizePolicy>
            <Layout>horizontal</Layout>
            <Size>0me,0me</Size>
            <Children>
              <WidgetGroup>
                <ObjectName>LibraryWrapper</ObjectName>
                <Layout>horizontal</Layout>
                <Children>
                  <Library>
                    <ObjectName>Library</ObjectName>
                    <Size>0me,0me</Size>
                    <BgColor>#000</BgColor>
                    <FgColor>#75001a</FgColor>
                    <TrackTableBackgroundColorOpacity>0.4</TrackTableBackgroundColorOpacity>
                  </Library>
                </Children>
                <Connection>
                  <ConfigKey>[Sidebar],sidebar_visible</ConfigKey>
                  <BindProperty>visible</BindProperty>
                  <Transform><Not/></Transform>
                </Connection>
              </WidgetGroup>
              <WidgetGroup>
                <ObjectName>SidebarWrapper</ObjectName>
                <Layout>horizontal</Layout>
                <Children>
                  <LibrarySidebar>
                    <ObjectName>LibrarySidebar</ObjectName>
                    <Size>0me,0me</Size>
                  </LibrarySidebar>
                </Children>
                <Connection>
                  <ConfigKey>[Sidebar],sidebar_visible</ConfigKey>
                  <BindProperty>visible</BindProperty>
                </Connection>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>
      <WidgetGroup>
        <ObjectName>Decks</ObjectName>
        <Layout>horizontal</Layout>
        <Size>0me,85max</Size>
        <Children>
          <Template src="skin:deck.xml">
            <SetVariable name="channel">1</SetVariable>
          </Template>
          <Template src="skin:deck.xml">
            <SetVariable name="channel">2</SetVariable>
          </Template>
        </Children>
      </WidgetGroup>
    </Children>
  </WidgetGroup>
</Template>
