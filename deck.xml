<Template>
  <WidgetGroup>
    <ObjectName>Deck</ObjectName>
    <Layout>vertical</Layout>
    <Children>
      <WidgetGroup>
        <ObjectName>DeckHotcuesContainer</ObjectName>
        <Layout>vertical</Layout>
        <Children>
          <Template src="skin:hotcue_bank.xml">
            <SetVariable name="channel"><Variable name="channel"/></SetVariable>
          </Template>
        </Children>
        <Connection>
          <ConfigKey>[Tab],overview</ConfigKey>
          <BindProperty>visible</BindProperty>
        </Connection>
      </WidgetGroup>
      <WidgetGroup>
        <ObjectName>DeckHeader</ObjectName>
        <Layout>horizontal</Layout>
        <Children>
          <WidgetGroup>
            <ObjectName>DeckChannelTitleWrapper</ObjectName>
            <Layout>horizontal</Layout>
            <Size>0me,25f</Size>
            <SizePolicy>min,min</SizePolicy>
            <Children>
              <Label>
                <ObjectName>DeckPlayingLeft</ObjectName>
                <Text>((</Text>
                <Connection>
                  <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>
                  <BindProperty>highlight</BindProperty>
                </Connection>
              </Label>
              <Label>
                <ObjectName>DeckChannelTitle</ObjectName>
                <Text>Deck<Variable name="channel"/></Text>
                <SizePolicy>min,me</SizePolicy>
              </Label>
              <Label>
                <ObjectName>DeckPlayingRight</ObjectName>
                <Text>))</Text>
                <Connection>
                  <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>
                  <BindProperty>highlight</BindProperty>
                </Connection>
              </Label>
            </Children>
          </WidgetGroup>
          <WidgetGroup>
            <ObjectName>DeckTitleWrapper</ObjectName>
            <Layout>horizontal</Layout>
            <SizePolicy>me,min</SizePolicy>
            <Children>
              <Label>
                <ObjectName>DeckTitleNote</ObjectName>
                <Text>&#9834;</Text>
              </Label>
              <TrackProperty>
                <ObjectName>DeckTitle</ObjectName>
                <TooltipId>track_title</TooltipId>
                <SizePolicy>me,25f</SizePolicy>
                <Property>title</Property>
                <Channel><Variable name="channel"/></Channel>
                <Elide>right</Elide>
              </TrackProperty>
            </Children>
          </WidgetGroup>
        </Children>
      </WidgetGroup>
      <WidgetGroup>
        <ObjectName>DeckInfo</ObjectName>
        <Layout>horizontal</Layout>
        <Children>
          <WidgetGroup>
            <ObjectName>DeckTrackNumberContainer</ObjectName>
            <Layout>vertical</Layout>
            <Size>85max,0me</Size>
            <Children>
              <WidgetGroup>
                <ObjectName>TrackNumberContainer</ObjectName>
                <Layout>vertical</Layout>
                <Size>0me,50max</Size>
                <Children>
                  <WidgetGroup>
                    <ObjectName>TrackNumberTitleWrapper</ObjectName>
                    <Layout>horizontal</Layout>
                    <Size>10min,10max</Size>
                    <Children>
                      <Label>
                        <ObjectName>TrackNumberTitle</ObjectName>
                        <Text>Track</Text>
                      </Label>
                    </Children>
                  </WidgetGroup>
                  <WidgetGroup>
                    <ObjectName>TrackNumberWrapper</ObjectName>
                    <Layout>horizontal</Layout>
                    <Size>0me,25max</Size>
                    <Children>
                      <Label>
                        <Size>0me,0me</Size>
                        <!-- Hacky way to align centered -->
                      </Label>
                      <TrackProperty>
                        <ObjectName>TrackNumber</ObjectName>
                        <Size>0me,0me</Size>
                        <Property>tracknumber</Property>
                        <Channel><Variable name="channel"/></Channel>
                        <Elide>right</Elide>
                      </TrackProperty>
                      <Label>
                        <Size>0me,0me</Size>
                        <!-- Hacky way to align centered -->
                      </Label>
                    </Children>
                  </WidgetGroup>
                </Children>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
          <WidgetGroup>
            <ObjectName>TrackTimeContainer</ObjectName>
            <Layout>vertical</Layout>
            <Size>0me,0me</Size>
            <Children>
              <Label>
                <ObjectName>DeckTrackTimeTitle</ObjectName>
                <Text>Time</Text>
                <Size>200me,25f</Size>
              </Label>
              <WidgetGroup>
                <ObjectName>DeckTrackTimeWrapper</ObjectName>
                <Layout>horizontal</Layout>
                <Size>0me,0me</Size>
                <Align>left</Align>
                <Children>
                  <SizeAwareStack>
                    <Children>
                      <NumberPos>
                        <ObjectName>DeckTrackTimeMini</ObjectName>
                        <MaximumSize>150,-1</MaximumSize>
                        <TooltipId>track_time</TooltipId>
                        <NumberOfDigits>6</NumberOfDigits>
                        <Channel><Variable name="channel"/></Channel>
                        <Connection>
                          <ConfigKey>[Controls],ShowDurationRemaining</ConfigKey>
                          <Transform>
                            <IsEqual>2</IsEqual>
                          </Transform>
                          <BindProperty>highlight</BindProperty>
                        </Connection>
                      </NumberPos>
                      <NumberPos>
                        <ObjectName>DeckTrackTime</ObjectName>
                        <MinimumSize>150,-1</MinimumSize>
                        <TooltipId>track_time</TooltipId>
                        <NumberOfDigits>6</NumberOfDigits>
                        <Channel><Variable name="channel"/></Channel>
                        <Connection>
                          <ConfigKey>[Controls],ShowDurationRemaining</ConfigKey>
                          <Transform>
                            <IsEqual>2</IsEqual>
                          </Transform>
                          <BindProperty>highlight</BindProperty>
                        </Connection>
                      </NumberPos>
                    </Children>
                  </SizeAwareStack>
                </Children>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
          <WidgetGroup>
            <ObjectName>TrackBPMRangeContainer</ObjectName>
            <Layout>vertical</Layout>
            <Size>65max,40max</Size>
            <Children>              
              <WidgetGroup>
                <ObjectName>DeckBPMRangePercent</ObjectName>
                <Size>30me,16f</Size>
                <Layout>horizontal</Layout>
                <Children>
                  <Label>
                    <ObjectName>BPMRangePlusMinus</ObjectName>
                    <Text>&#177;</Text>
                  </Label>
                  <RateRange>
                    <TooltipId>rate_range_display</TooltipId>
                    <ObjectName>RateDisplay</ObjectName>
                    <Channel><Variable name="channel" /></Channel>
                    <Display>range</Display>
                  </RateRange>
                </Children>
              </WidgetGroup>
              <WidgetGroup>
                <ObjectName>RateDisplay<Variable name="channel"/></ObjectName>
                <Layout>horizontal</Layout>
                <Size>0me,0me</Size>
                <Children>
                  <NumberRate>
                    <TooltipId>rate_display</TooltipId>
                    <Channel><Variable name="channel"/></Channel>
                    <NumberOfDigits>1</NumberOfDigits>
                  </NumberRate>
                  <Label>
                    <ObjectName>BPMPercent</ObjectName>
                    <Text>%</Text>
                  </Label>
                </Children>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
          <WidgetGroup>
            <ObjectName>TrackBPMContainer</ObjectName>
            <Layout>vertical</Layout>
            <Size>75max,0me</Size>
            <Children>
              <Label>
                <ObjectName>DeckTempoTitle</ObjectName>
                <Text>Tempo</Text>
                <Size>0me,25f</Size>
              </Label>
              <WidgetGroup>
                <ObjectName>DeckBPMWrapper</ObjectName>
                <Layout>vertical</Layout>
                <Size>0me,0me</Size>
                <Children>
                  <NumberBpm>
                    <ObjectName>DeckBPM</ObjectName>
                    <TooltipId>visual_bpm</TooltipId>
                    <Channel><Variable name="channel"/></Channel>
                    <Connection>
                      <ConfigKey>[Channel<Variable name="channel"/>],visual_bpm</ConfigKey>
                    </Connection>
                  </NumberBpm>
                  <WidgetGroup>
                    <ObjectName>DeckBPMTitleWrapper</ObjectName>
                    <Layout>horizontal</Layout>
                    <Children>
                      <Label>
                        <ObjectName>DeckBPMTitle</ObjectName>
                        <Text>BPM</Text>
                      </Label>
                    </Children>
                  </WidgetGroup>
                </Children>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
        </Children>
        <Connection>
          <ConfigKey>[Tab],overview</ConfigKey>
          <!-- Only show info in overview -->
          <BindProperty>visible</BindProperty>
        </Connection>
      </WidgetGroup>
      <WidgetGroup>
        <ObjectName>DeckOverviewContainer</ObjectName>
        <Layout>vertical</Layout>
        <Size>0me,50f</Size>
        <Children>
          <Overview>
            <ObjectName>DeckOverview</ObjectName>
            <Size>0me,100f</Size>
            <Channel><Variable name="channel"/></Channel>
            <BgColor>#000000</BgColor>
            <SignalHighColor>#007DE1</SignalHighColor>
            <SignalMidColor>#007DE1</SignalMidColor>
            <SignalLowColor>#007DE1</SignalLowColor>
            <SignalRGBHighColor></SignalRGBHighColor>
            <SignalRGBMidColor></SignalRGBMidColor>
            <SignalRGBLowColor></SignalRGBLowColor>
            <SignalColor>#222222</SignalColor>
            <PlayedOverlayColor>#40FFFFFF</PlayedOverlayColor>
            <PlayPosColor>#FFFFFF</PlayPosColor>
            <EndOfTrackColor>#EA0000</EndOfTrackColor>
            <Mark>
              <Control>cue_point</Control>
              <Color>#eb870f</Color>
            </Mark>
	    <Mark>
          <Control>hotcue_1_position</Control>
          <Text>A</Text>
          <Color>#f44040</Color>
          <TextColor>#f44040</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_2_position</Control>
          <Text>B</Text>
          <Color>#0ddcf2</Color>
          <TextColor>#0ddcf2</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_3_position</Control>
          <Text>C</Text>
          <Color>#a5df13</Color>
          <TextColor>#a5df13</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_4_position</Control>
          <Text>D</Text>
          <Color>#9d4cfd</Color>
          <TextColor>#9d4cfd</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_5_position</Control>
          <Text>E</Text>
          <Color>#3fec2b</Color>
          <TextColor>#3fec2b</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_6_position</Control>
          <Text>F</Text>
          <Color>#e6681c</Color>
          <TextColor>#e6681c</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_7_position</Control>
          <Text>G</Text>
          <Color>#2749c8</Color>
          <TextColor>#2749c8</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_8_position</Control>
          <Text>H</Text>
          <Color>#c7b205</Color>
          <TextColor>#c7b205</TextColor>
          <Align>top</Align>
        </Mark>
            <Mark>
              <Control>loop_start_position</Control>
              <Color>#6ee128</Color>
            </Mark>
            <Mark>
              <Control>loop_end_position</Control>
              <Color>#6ee128</Color>
            </Mark>
            <MarkRange>
              <StartControl>loop_start_position</StartControl>
              <EndControl>loop_end_position</EndControl>
              <EnabledControl>loop_enabled</EnabledControl>
              <Color>#6ee128</Color>
              <Opacity>0.8</Opacity>
              <DisabledColor>#acacac</DisabledColor>
              <DisabledOpacity>0.4</DisabledOpacity>
            </MarkRange>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],playposition</ConfigKey>
            </Connection>
          </Overview>
        </Children>
      </WidgetGroup>
    </Children>
  </WidgetGroup>
</Template>
